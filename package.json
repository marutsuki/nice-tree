{
  "name": "bamboo-tree",
  "version": "0.0.1",
  "description": "Parse your file directory into a nice index.html home page.",
  "type": "module",
  "bin": {
    "bamboo-tree": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --test --experimental-strip-types src/tree.spec.ts src/template.spec.ts",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Lucien Lu",
    "email": "lucienlu2000@gmail.com",
    "url": "https://marutsuki.com/"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.13.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "license": "ISC",
  "dependencies": {
    "commander": "^15.0.0",
    "ejs": "^6.0.1"
  }
}
